AUTODNS_BASE_URL=https://api.autodns.com/v1
AUTODNS_USERNAME=
AUTODNS_PASSWORD=
AUTODNS_CONTEXT=
AUTODNS_USER_AGENT=tenbyte-autodns-backup/1.0

BACKUP_MODE=incremental
BACKUP_CONCURRENCY=2
BACKUP_REQUESTS_PER_SECOND=1
BACKUP_REQUEST_TIMEOUT_MS=30000
BACKUP_MAX_RETRIES=5
FORCE_REEXPORT_AFTER_DAYS=7
MISSING_CONFIRMATION_RUNS=3
MAX_INVENTORY_DROP_PERCENT=1
MAX_FAILED_ZONES=5
INVENTORY_PAGE_SIZE=500

DATABASE_PATH=/data/backup.sqlite
WORK_DIRECTORY=/data/work

STORAGE_DRIVER=s3
LOCAL_BACKUP_PATH=/backup

GIT_EXPORT_ENABLED=false
GIT_EXPORT_PATH=/git-export
GIT_EXPORT_WRITE_BIND=true

S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=
S3_PREFIX=autodns
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_SERVER_SIDE_ENCRYPTION=AES256
S3_KMS_KEY_ID=

ALERT_WEBHOOK_URL=
LOG_LEVEL=info
