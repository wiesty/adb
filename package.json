{
  "name": "autodns-backup",
  "version": "1.0.0",
  "description": "Production-ready export-only backup client for InterNetX AutoDNS DomainRobot DNS zones.",
  "license": "PolyForm-Internal-Use-1.0.0",
  "type": "module",
  "bin": {
    "autodns-backup": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "NODE_OPTIONS='--experimental-sqlite --no-warnings' vitest run",
    "start": "tsc -p tsconfig.json && DATABASE_PATH=${DATABASE_PATH:-./data/backup.sqlite} WORK_DIRECTORY=${WORK_DIRECTORY:-./data/work} LOCAL_BACKUP_PATH=${LOCAL_BACKUP_PATH:-./backup} GIT_EXPORT_PATH=${GIT_EXPORT_PATH:-./git-export} node --no-warnings --experimental-sqlite dist/src/cli/index.js"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.614.0",
    "commander": "^12.1.0",
    "pino": "^9.3.2",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^22.5.0",
    "eslint": "^9.8.0",
    "globals": "^15.8.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.6.0"
}
